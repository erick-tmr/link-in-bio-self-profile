.DS_Store

# Static assets are hosted in S3 (s3://www.ericktakeshi.com.br/assets/),
# not tracked in git. Publish them with ./scripts/sync-assets.sh
web/assets/

# Build tooling output and dependencies (regenerated by `npm run build`).
node_modules/
dist/

# Local secrets (R2 credentials for scripts/publish-assets.mjs). Never commit
# real values — only the .env.example template is tracked.
.env
.env.*
!.env.example
