.DS_Store

# Images + audio are hosted on Cloudflare R2 (cdn.ericktakeshi.com.br), not in
# git. Publish them with `npm run publish-assets`.
web/assets/

# Build tooling output and dependencies (regenerated by `npm run build`).
node_modules/
dist/

# Playwright MCP scratch output (screenshots, page/console dumps).
.playwright-mcp/

# Local secrets (R2 credentials for scripts/publish-assets.mjs). Never commit
# real values — only the .env.example template is tracked.
.env
.env.*
!.env.example
