# Local secrets for scripts/publish-assets.mjs (Cloudflare R2 asset publishing).
# Copy this file to .env and fill in the values. .env is gitignored — NEVER
# commit real credentials. Real shell env vars override anything set here.

# Cloudflare account id. The R2 S3 API endpoint is derived from it:
#   https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=

# R2 bucket that holds the assets (defaults to ericktakeshi-cdn if omitted).
R2_BUCKET=ericktakeshi-cdn

# --- Auth: pick ONE of the two options below ---

# Option A (self-contained): R2 API token keys.
# Cloudflare dashboard: R2 -> Manage R2 API Tokens -> Create API Token
# (Object Read & Write, scoped to the bucket). The secret is shown once.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Option B: instead of the keys above, use a preconfigured local `aws` profile.
# Leave the keys blank and set this to the profile name (defaults to r2-cdn).
# R2_PROFILE=r2-cdn
